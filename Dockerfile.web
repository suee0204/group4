# Smart Fire Alert System - Web Application Dockerfile
# This Dockerfile is for the Flask web interface and API

FROM python:3.9-slim-bullseye

# Set maintainer information
LABEL maintainer="Smart Fire Alert System Team"
LABEL description="Flask Web Interface for Fire Alert System"
LABEL version="1.0"

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV FLASK_APP=App.py
ENV FLASK_ENV=production
ENV FLASK_DEBUG=0

# Set working directory
WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    # Build tools for Python packages
    build-essential \
    # MySQL client libraries
    default-libmysqlclient-dev \
    pkg-config \
    # Network tools
    curl \
    # Cleanup
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements and install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Copy the HAL modules (needed for AlertSystem integration)
COPY src/hal/ ./hal/

# Copy the web application source code
COPY src/App.py .
COPY src/AlertSystem.py .
COPY src/TempSmoke.py .

# Copy web templates and static files
COPY src/templates/ ./templates/
COPY src/static/ ./static/

# Copy database initialization scripts
COPY src/on-duty.sql .
COPY src/off-duty.sql .

# Create non-root user for security
RUN groupadd -r webapp && useradd -r -g webapp webuser
RUN chown -R webuser:webapp /app
USER webuser

# Expose the Flask application port
EXPOSE 5000

# Health check for the web application
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:5000/ || exit 1

# Default command to run the Flask application with Gunicorn
CMD ["gunicorn", "--bind", "0.0.0.0:5000", "--workers", "4", "--timeout", "120", "App:app"]

# Alternative commands:
# Development mode: docker run -it -p 5000:5000 smart-fire-web python App.py
# Debug mode: docker run -it -p 5000:5000 -e FLASK_DEBUG=1 smart-fire-web python App.py